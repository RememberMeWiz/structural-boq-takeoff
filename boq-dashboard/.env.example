# Copy this file to .env and fill in your Supabase project's PUBLIC values.
#
# IMPORTANT: only use the "anon" / "public" key here, never the "service_role" key.
# The anon key is safe for client-side code because Row Level Security (RLS)
# policies on your tables govern what it can actually read or write.
# Find both values in: Supabase Dashboard -> Project Settings -> API.

VITE_SUPABASE_URL=https://ickbqcdbyheyqyqfjpzv.supabase.co
VITE_SUPABASE_ANON_KEY=paste-your-anon-key-here
